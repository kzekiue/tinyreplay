# TinyReplay server configuration.
#
# Copy to .env (gitignored) and adjust. Every value is optional; the defaults
# shown produce a working, open instance suitable for local use. Lock down
# ALLOWED_ORIGINS, DASHBOARD_PASSWORD, and INGEST_TOKEN before exposing an
# instance publicly. Never commit real secrets; this file holds placeholders.

# Port the server listens on.
# Default: 3000. Required: no.
PORT=3000

# Directory that holds the SQLite database file (tinyreplay.db).
# Default: <cwd>/data locally, /app/data in Docker. Required: no.
DATA_DIR=./data

# Comma-separated CORS allowlist for the ingest endpoint, or * for any origin.
# Default: * (open, convenient for local testing). Required: no.
# Security: set this to your site origins in production, e.g.
# ALLOWED_ORIGINS=https://example.com,https://app.example.com
ALLOWED_ORIGINS=*

# When set, the dashboard requires HTTP Basic auth (any username, this password).
# Default: unset (dashboard is open). Required: no.
# Security: set this before exposing the dashboard. It is a secret.
# DASHBOARD_PASSWORD=

# When set, POST /api/ingest requires this token (SDK `token` config or
# `Authorization: Bearer <token>`).
# Default: unset (ingest is open). Required: no.
# Security: set this before exposing ingest. It is a secret.
# INGEST_TOKEN=

# Delete sessions older than N days, swept hourly.
# Default: unset / 0 (keep everything). Required: no.
# RETENTION_DAYS=30

# Ingest requests allowed per minute per IP.
# Default: 100. Required: no.
RATE_LIMIT_PER_MIN=100

# Maximum ingest request body size in bytes; larger bodies receive 413.
# Default: 5000000 (5 MB). Required: no.
MAX_PAYLOAD_BYTES=5000000
